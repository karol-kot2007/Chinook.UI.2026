<Window x:Class="Chinook.UI.AlbumInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Chinook.UI"
        mc:Ignorable="d"
        Title="AlbumInfoWindow" Width="800" Height="600">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <local:AlbumInfoControl Grid.Row="0" 
                                x:Name="AlbumInfoControl" 
                                HorizontalAlignment="Stretch" 
                                VerticalAlignment="Stretch" 
                                Loaded="AlbumInfoControl_Loaded"  />

    <StackPanel Grid.Row="1" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="10">
      <Button Content="close" x:Name="CloseBtn" Click="CloseBtn_Click" Width="50" Margin="2"/>
      <Button Content="ok" x:Name="OkBtn" Click="OkBtn_Click" Width="50" Margin="2"/>
      <Button Content="cancel" x:Name="CancelBtn" Click="CancelBtn_Click" Width="60" Margin="2"/>
    </StackPanel>
  </Grid>
</Window>